# Copy to `.env.local` and fill in values. Next.js loads `.env.local` automatically (gitignored).

# --- Typeform (required for embed + server) ---
# Form id from the URL: https://form.typeform.com/to/<id>
NEXT_PUBLIC_TYPEFORM_FORM_ID=

# Webhook HMAC secret from Typeform (production / tunneled local URL)
TYPEFORM_WEBHOOK_SECRET=

# Set to "true" only when debugging webhooks without a valid signature (e.g. local tunnel issues)
TYPEFORM_SKIP_SIGNATURE_VERIFY=false

# Personal access token — needed for local dev without a public webhook (Responses API fallback)
TYPEFORM_ACCESS_TOKEN=

# Optional: override Typeform field refs if yours differ from age / owns_car / brands
# TYPEFORM_REF_AGE=age
# TYPEFORM_REF_owns_car=owns_car
# TYPEFORM_REF_brands=brands

# --- ElevenLabs (required for Part 2 voice) ---
ELEVENLABS_API_KEY=
ELEVENLABS_AGENT_ID=
# In the ElevenLabs agent, allow system prompt override from the client if you use
# overrides.agent.prompt (this repo). Otherwise use dashboard prompt + dynamicVariables only.

# --- Optional: client ---
# Show “Testing tools” (e.g. New participant ID) in production — same as dev by default
# NEXT_PUBLIC_ENABLE_SESSION_TOOLS=true

# Log the full resolved Alex system prompt in the browser console when starting voice
# NEXT_PUBLIC_DEBUG_VOICE_PROMPT=true
